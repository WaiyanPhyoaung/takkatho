  <script>
    const canvas = document.getElementById(
      "matrix-canvas",
    ) as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext("2d");

      let width = 0;
      let height = 0;
      let columns = 0;
      const fontSize = 16;
      let drops: {
        y: number;
        speed: number;
        length: number;
        chars: string[];
      }[] = [];

      const init = () => {
        width = canvas.width = window.innerWidth;
        height = canvas.height = canvas.parentElement?.offsetHeight || 800;
        columns = Math.floor(width / fontSize);

        drops = [];
        for (let i = 0; i < columns; i++) {
          resetDrop(i, true);
        }
      };

      const resetDrop = (i: number, initial = false) => {
        drops[i] = {
          y: initial
            ? Math.random() * height * -1.5
            : Math.random() * -100 - 50,
          speed: 0.7 + Math.random() * 1.5,
          length: 15 + Math.floor(Math.random() * 30),
          chars: [],
        };

        for (let j = 0; j < drops[i].length; j++) {
          drops[i].chars.push(Math.random() > 0.5 ? "0" : "1");
        }
      };

      init();

      const draw = () => {
        if (!ctx) return;
        ctx.clearRect(0, 0, width, height);

        const isDark = document.documentElement.classList.contains("dark");

        const headColor = isDark ? "#ffffff" : "#ea580c";
        const glowColor = isDark ? "#f97316" : "transparent";
        const tailRGB = isDark ? "249, 115, 22" : "234, 88, 12";

        ctx.font = `bold ${fontSize}px "Courier New", monospace`;
        ctx.textAlign = "center";

        for (let i = 0; i < drops.length; i++) {
          const drop = drops[i];
          if (!drop) continue;

          for (let j = 0; j < drop.length; j++) {
            const charY = drop.y - j * fontSize;

            if (charY < -fontSize || charY > height + fontSize) continue;

            if (Math.random() < 0.02) {
              drop.chars[j] = Math.random() > 0.5 ? "0" : "1";
            }

            if (j === 0) {
              ctx.fillStyle = headColor;
              if (isDark) {
                ctx.shadowBlur = 15;
                ctx.shadowColor = glowColor;
              } else {
                ctx.shadowBlur = 0;
              }
            } else {
              ctx.shadowBlur = 0;
              const alpha = 1 - j / drop.length;
              const fade = Math.pow(alpha, 1.5);
              ctx.fillStyle = `rgba(${tailRGB}, ${fade})`;
            }

            ctx.fillText(drop.chars[j], i * fontSize + fontSize / 2, charY);
          }

          drop.y += drop.speed;

          if (
            drop.y - drop.length * fontSize > height &&
            Math.random() > 0.98
          ) {
            resetDrop(i);
          }
        }

        requestAnimationFrame(draw);
      };

      draw();

      window.addEventListener("resize", () => {
        init();
      });
    }
  </script>

