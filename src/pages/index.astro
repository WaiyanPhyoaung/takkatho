---
import StandaloneLayout from "../layouts/StandaloneLayout.astro";
import { coursesData } from "@/components/CoursesListing";
---

<StandaloneLayout
  title="တက္ကသိုလ် - Myanmar Programming Learning Platform"
  description="မြန်မာဘာသာဖြင့် programming သင်ခန်းစာများကို လေ့လာပါ။ TypeScript, WebSocket, Git, Web Performance နှင့် အခြား နည်းပညာများ"
>
  <div class="neo-page neo-home">
    <!-- Hero Section -->
    <section class="neo-hero relative overflow-hidden">
      <!-- Animated Background -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-gray-50 via-white to-gray-50 dark:from-orange-950/40 dark:via-gray-950/80 dark:to-gray-900/80"
      >
      </div>
      <canvas
        id="matrix-canvas"
        class="absolute inset-0 w-full h-full pointer-events-none opacity-60 dark:opacity-80 mix-blend-multiply dark:mix-blend-screen"
      ></canvas>

      <!-- Gradient Orbs -->
      <div
        class="absolute top-20 left-10 w-72 h-72 bg-amber-400/20 dark:bg-amber-500/10 rounded-full blur-3xl animate-pulse"
      >
      </div>
      <div
        class="absolute bottom-20 right-10 w-96 h-96 bg-orange-400/20 dark:bg-orange-500/10 rounded-full blur-3xl animate-pulse"
        style="animation-delay: 1s;"
      >
      </div>
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-yellow-400/10 dark:bg-yellow-500/5 rounded-full blur-3xl"
      >
      </div>

      <div
        class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32"
      >
        <div class="text-center">
          <!-- Main Heading -->
          <h1
            class="text-4xl sm:text-5xl lg:text-7xl font-bold mb-6 leading-tight relative"
          >
            <span
              class="text-orange-600 dark:text-orange-500 drop-shadow-[0_0_25px_rgba(234,88,12,0.4)]"
              >တက္ကသိုလ်</span
            >
            <br />
          </h1>

          <!-- Subtitle -->
          <p
            class="text-lg sm:text-xl text-gray-700 dark:text-gray-300 max-w-3xl mx-auto mb-10 leading-relaxed font-medium"
          >
            <span
              class="inline-block py-2 bg-gradient-to-r from-amber-600 via-orange-600 to-red-600 dark:from-amber-400 dark:via-orange-400 dark:to-red-400 bg-clip-text text-transparent"
            >
              မိမိဘာသာစကားဖြင့် နက်နက်ရှိုင်းရှိုင်းနားလည်အောင် လေ့လာပါ။
            </span>
          </p>

          <!-- CTA Buttons -->
          <div
            class="hero-cta flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 relative z-10"
          >
            <a
              href="/courses"
              class="neo-btn group flex items-center py-4 md:px-4 lg:px-8 gap-3 bg-orange-500 text-white font-semibold text-lg hover:-translate-y-0.5 transition-all duration-300"
            >
              <span>သင်ခန်းစာများကို ကြည့်ရှုရန်</span>
              <svg
                class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </a>
            <a
              href="/about"
              class="neo-btn group flex items-center gap-3 py-4 md:px-4 lg:px-8 bg-white/80 backdrop-blur-md dark:bg-gray-900/80 text-gray-800 dark:text-gray-200 font-semibold text-lg hover:-translate-y-0.5 transition-all duration-300"
            >
              <span>ကျွန်ုပ်တို့အကြောင်း</span>
              <svg
                class="w-5 h-5 group-hover:translate-x-1 transition-transform text-orange-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>

          <!-- Stats -->
          <div
            class="neo-stats inline-flex flex-wrap items-center justify-center gap-8 md:gap-12 px-8 py-6 relative z-10"
          >
            <div class="text-center">
              <div
                class="text-3xl md:text-4xl font-bold text-orange-600 dark:text-orange-400"
              >
                {coursesData.length}+
              </div>
              <div
                class="text-sm text-orange-800/70 dark:text-orange-300/70 mt-1"
              >
                Courses
              </div>
            </div>
            <div class="w-px h-12 bg-orange-200/60 dark:bg-orange-900/50"></div>
            <div class="text-center">
              <div
                class="text-3xl md:text-4xl font-bold text-orange-600 dark:text-orange-400"
              >
                150+
              </div>
              <div
                class="text-sm text-orange-800/70 dark:text-orange-300/70 mt-1"
              >
                Lessons
              </div>
            </div>
            <div
              class="w-px h-12 bg-orange-200/60 dark:bg-orange-900/50 hidden sm:block"
            >
            </div>
            <div class="text-center hidden sm:block">
              <div
                class="text-3xl md:text-4xl font-bold text-orange-600 dark:text-orange-400"
              >
                100%
              </div>
              <div
                class="text-sm text-orange-800/70 dark:text-orange-300/70 mt-1"
              >
                Free
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Where to Start Section -->
    <section class="py-16 dark:bg-[#0c0a09] neo-alt relative">
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#f9731610_1px,transparent_1px),linear-gradient(to_bottom,#f9731610_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"
      >
      </div>
      <div
        class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10"
      >
        <h2
          class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4"
        >
          ဘယ်ကနေ စတင်လေ့လာရမလဲ?
        </h2>
        <p class="text-lg text-gray-700 dark:text-gray-300 mb-8 font-medium">
          Programming ကို စတင်လေ့လာမည့်သူများအတွက် ဘာတွေလေ့လာရမလဲဆိုတာကို ဒီ
          Video လေးမှာ ရှင်းပြပေးထားပါတယ်။
        </p>
        <div class="flex justify-center">
          <div
            class="relative w-full max-w-2xl overflow-hidden rounded-3xl shadow-2xl shadow-orange-500/10 dark:shadow-orange-500/5 ring-1 ring-black/5 dark:ring-white/5"
            style="padding-top: 56.25%;"
          >
            <iframe
              class="absolute top-0 left-0 w-full h-full"
              src="https://www.youtube.com/embed/mgY1YjAP9oc"
              title="Where to start learning programming"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- Community Banners -->
    <section class="py-4 dark:bg-[#0c0a09] neo-alt relative">
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row gap-4 justify-center relative z-10"
      >
        <!-- Facebook Follow Banner -->
        <div
          class="flex flex-1 items-center justify-center gap-4 px-6 py-4 rounded-3xl bg-white/50 backdrop-blur-md dark:bg-[#12100e]/60 ring-1 ring-black/5 dark:ring-white/5 hover:shadow-lg hover:shadow-orange-500/5 transition-all duration-300"
        >
          <svg
            class="w-6 h-6 text-blue-600 dark:text-blue-500 flex-shrink-0"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path>
          </svg>
          <p class="text-sm text-gray-700 dark:text-gray-300">
            Course updates များအတွက်
            <a
              href="https://www.facebook.com/share/1DDxrT1dja/?mibextid=wwXIfr"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold text-blue-600 dark:text-blue-400 hover:text-blue-500 hover:underline transition-colors"
            >
              Facebook Page
            </a>
            ကို Follow လုပ်ထားပေးပါ။
          </p>
        </div>

        <!-- YouTube Subscribe Banner -->
        <div
          class="flex flex-1 items-center justify-center gap-4 px-6 py-4 rounded-3xl bg-white/50 backdrop-blur-md dark:bg-[#12100e]/60 ring-1 ring-black/5 dark:ring-white/5 hover:shadow-lg hover:shadow-red-500/5 transition-all duration-300"
        >
          <svg
            class="w-6 h-6 text-red-600 flex-shrink-0"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
            ></path>
          </svg>
          <p class="text-sm text-gray-700 dark:text-gray-300">
            ကျွန်ုပ်တို့ကို ကူညီရန်အတွက်
            <a
              href="https://www.youtube.com/@takkatho"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold text-red-600 dark:text-red-400 hover:underline"
            >
              YouTube Channel
            </a>
            ကို Like နှင့် Subscribe လုပ်ပေးပါ။
          </p>
        </div>
      </div>
    </section>

    <!-- Popular Courses Section -->
    <section class="py-20 dark:bg-[#0c0a09] neo-alt relative">
      <div
        class="absolute top-0 right-0 w-full h-[500px] bg-gradient-to-b from-[#f97316]/5 to-transparent dark:from-[#ea580c]/5 pointer-events-none mix-blend-multiply dark:mix-blend-screen"
      >
      </div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Section Header -->
        <div class="text-center mb-16">
          <h2
            class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4 drop-shadow-sm"
          >
            လူကြိုက်များသော သင်ခန်းစာများ
          </h2>
          <!-- <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto"> -->
          <!-- Beginner မှ Advanced အဆင့်အထိ စနစ်တကျ လေ့လာနိုင်မည့် သင်တန်းများ
          </p> -->
        </div>

        <!-- Course Grid -->
        <div
          class="neo-card-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8"
        >
          <!-- Git Version Control -->
          <a href="/git-course/introduction/why-git" class="group">
            <div
              class="neo-card relative h-full p-6 rounded-2xl bg-gradient-to-br hover:shadow-orange-500/10 hover:-translate-y-1 transition-all duration-300"
            >
              <div class="flex items-start justify-between mb-4">
                <div
                  class="p-3 rounded-xl bg-gradient-to-br from-orange-500 to-red-500 text-white shadow-lg shadow-orange-500/25"
                >
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
                    ></path>
                  </svg>
                </div>
                <span
                  class="px-2.5 py-1 rounded-lg bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-300 text-xs font-medium"
                  >Beginner</span
                >
              </div>
              <h3
                class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors"
              >
                Git Version Control
              </h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">
                Codes အပြောင်းအလဲများကို စနစ်တကျ စီမံခန့်ခွဲခြင်း Teamwork အတွက်
              </p>
              <div
                class="flex items-center gap-4 text-xs text-gray-500 dark:text-gray-500"
              >
                <span class="flex items-center gap-1">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                    ></path>
                  </svg>
                  20 lessons
                </span>
                <span class="flex items-center gap-1">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  4 weeks
                </span>
              </div>
            </div>
          </a>

          <!-- Advanced TypeScript -->
          <a
            href="/advanced-typescript/why-is-advanced-ts-needed/why-advanced-typescript"
            class="group"
          >
            <div
              class="neo-card relative h-full p-6 rounded-2xl bg-gradient-to-br hover:shadow-blue-500/10 hover:-translate-y-1 transition-all duration-300"
            >
              <div class="flex items-start justify-between mb-4">
                <div
                  class="p-3 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 text-white shadow-lg shadow-blue-500/25"
                >
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                  </svg>
                </div>
                <span
                  class="px-2.5 py-1 rounded-lg bg-red-100 dark:bg-red-900/50 text-red-700 dark:text-red-300 text-xs font-medium"
                  >Advanced</span
                >
              </div>
              <h3
                class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"
              >
                Advanced TypeScript
              </h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">
                TypeScript ၏ အဆင့်မြင့် သဘောတရားများကို နက်နက်နဲနဲ လေ့လာခြင်း
              </p>
              <div
                class="flex items-center gap-4 text-xs text-gray-500 dark:text-gray-500"
              >
                <span class="flex items-center gap-1">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                    ></path>
                  </svg>
                  25 lessons
                </span>
                <span class="flex items-center gap-1">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  10 weeks
                </span>
              </div>
            </div>
          </a>

          <!-- AI Proficiency -->
          <a href="/ai-proficiency/foundations/introduction" class="group">
            <div
              class="neo-card relative h-full p-6 rounded-2xl bg-gradient-to-br hover:shadow-purple-500/10 hover:-translate-y-1 transition-all duration-300"
            >
              <div class="flex items-start justify-between mb-4">
                <div
                  class="p-3 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 text-white shadow-lg shadow-purple-500/25"
                >
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
                    ></path>
                  </svg>
                </div>
                <span
                  class="px-2.5 py-1 rounded-lg bg-purple-100 dark:bg-purple-900/50 text-purple-700 dark:text-purple-300 text-xs font-medium"
                  >NEW</span
                >
              </div>
              <h3
                class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors"
              >
                AI Proficiency
              </h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">
                AI Tools များကို ထိရောက်စွာ အသုံးပြုပြီး Developer စွမ်းဆောင်ရည်
                မြှင့်တင်နည်း
              </p>
              <div
                class="flex items-center gap-4 text-xs text-gray-500 dark:text-gray-500"
              >
                <span class="flex items-center gap-1">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                    ></path>
                  </svg>
                  16 lessons
                </span>
                <span class="flex items-center gap-1">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  12 weeks
                </span>
              </div>
            </div>
          </a>

          <!-- HTML -->
          <a href="/html/introduction/welcome-to-html" class="group">
            <div
              class="neo-card relative h-full p-6 rounded-2xl bg-gradient-to-br hover:shadow-orange-500/10 hover:-translate-y-1 transition-all duration-300"
            >
              <div class="flex items-start justify-between mb-4">
                <div
                  class="p-3 rounded-xl bg-gradient-to-br from-orange-600 to-red-500 text-white shadow-lg shadow-orange-500/25"
                >
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                  </svg>
                </div>
                <span
                  class="px-2.5 py-1 rounded-lg bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-300 text-xs font-medium"
                  >Beginner</span
                >
              </div>
